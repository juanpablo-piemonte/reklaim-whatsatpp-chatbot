MYSQL_URL=mysql+pymysql://user:password@localhost:3306/reklaim_whatsapp_ai

# Meta / WhatsApp Cloud API
WHATSAPP_APP_SECRET=          # from Meta App → App Settings → Basic → App Secret
WHATSAPP_VERIFY_TOKEN=        # any string you choose; must match Meta webhook config
WHATSAPP_ACCESS_TOKEN=        # from Meta App → WhatsApp → API Setup → Temporary token
WHATSAPP_PHONE_NUMBER_ID=     # from Meta App → WhatsApp → API Setup → Phone number ID

# Reklaim chatbot API (dealers_chatbot namespace)
REKLAIM_API_URL=http://localhost:5001
DEALERS_CHATBOT_API_KEY=

# AWS — IAM user needs bedrock:InvokeModel on the model ARN
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=            # optional — only needed when using temporary credentials

BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0